<?xml version="1.0" encoding="UTF-8"?>
<!--
  ロギング設定（IMPL-08、共通部品設計.md §4）。
  - 出力先: 標準出力（コンテナ運用前提。集約先はインフラ構築フェーズで確定・運用設計.md 参照）
  - リクエストID（MDC・RequestIdFilter が設定）をパターンへ含め、障害調査での追跡を可能にする（R-SEC-052）
  - ログレベルの使い分け（INFO/WARN/ERROR）はロガー呼び出し側（GlobalExceptionHandler 等）で制御する
  - 機微情報（パスワード・トークン・氏名・電話番号・メールアドレス）は SensitiveDataMasker でマスクしてから
    ログ出力する運用とし、本設定ファイルではパターンのみを定義する
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [requestId=%X{requestId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
